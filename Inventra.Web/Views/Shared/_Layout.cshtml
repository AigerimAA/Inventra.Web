@inject Microsoft.Extensions.Localization.IStringLocalizer<Inventra.Web.SharedResource> L

<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Inventra</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body style="min-height:100vh; display:flex; flex-direction:column;">
    <header>
        <nav class="navbar navbar-expand-lg border-bottom mb-3">
            <div class="container-fluid">

                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo.svg" alt="Inventra" height="44" style="margin-left:20px; margin-top:4px;" />
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">

                    <form class="d-flex mx-auto" style="width: 400px;"
                          asp-controller="Search" asp-action="Index" method="get">
                        <input class="form-control me-2" type="search" name="q"
                               placeholder="@L["SearchPlaceholder"]"
                               value="@ViewData["SearchQuery"]" />
                        <button class="btn btn-outline-primary" type="submit">@L["Search"]</button>
                    </form>

                    <ul class="navbar-nav ms-auto align-items-center gap-2">

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Profile" asp-action="Index">
                                    @L["MyInventories"]
                                </a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                    @User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Profile" asp-action="Index">@L["Profile"]</a>
                                    </li>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-controller="Admin"
                                               asp-action="Index">@L["AdminPanel"]</a>
                                        </li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout"
                                              method="post">
                                            <button class="dropdown-item text-danger">@L["Logout"]</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account"
                                   asp-action="Login">@L["Login"]</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm"
                                       asp-controller="Account"
                                       asp-action="Register">
                                    @L["Register"]
                                </a>
                            </li>
                        }
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0097a7" stroke-width="2" stroke-linecap="round" style="vertical-align:middle; margin-right:2px;">
                                    <circle cx="12" cy="12" r="10" />
                                    <line x1="2" y1="12" x2="22" y2="12" />
                                    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                                </svg>
                                @System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName.ToUpper()
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item" href="@Url.Action("SetLanguage", "Account", new { lang = "en", returnUrl = Context.Request.Path + Context.Request.QueryString })">
                                        🇬🇧 English
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="@Url.Action("SetLanguage", "Account", new { lang = "ru", returnUrl = Context.Request.Path + Context.Request.QueryString })">
                                        🇷🇺 Русский
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="@Url.Action("SetLanguage", "Account", new { lang = "kk", returnUrl = Context.Request.Path + Context.Request.QueryString })">
                                        🇰🇿 Қазақша
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <li class="nav-item">
                            <button class="btn btn-sm" id="themeToggle"
                                    style="border:1.5px solid #0097a7; color:#0097a7; background:transparent; padding:4px 8px; border-radius:6px;">
                                <svg id="iconMoon" width="16" height="16" viewBox="0 0 24 24" fill="white" stroke="#0097a7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                                </svg>
                                <svg id="iconSun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#0097a7" stroke-width="2.5" stroke-linecap="round" style="display:none;">
                                    <circle cx="12" cy="12" r="4" fill="white" />
                                    <line x1="12" y1="2" x2="12" y2="5" />
                                    <line x1="12" y1="19" x2="12" y2="22" />
                                    <line x1="4.93" y1="4.93" x2="7.05" y2="7.05" />
                                    <line x1="16.95" y1="16.95" x2="19.07" y2="19.07" />
                                    <line x1="2" y1="12" x2="5" y2="12" />
                                    <line x1="19" y1="12" x2="22" y2="12" />
                                    <line x1="4.93" y1="19.07" x2="7.05" y2="16.95" />
                                    <line x1="16.95" y1="7.05" x2="19.07" y2="4.93" />
                                </svg>
                            </button>
                        </li>

                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-fluid px-4" style="flex:1;">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-auto py-3">
        <div class="container text-center">
            <span>&copy; 2026 Inventra</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
            const themeToggle = document.getElementById('themeToggle');
            const iconMoon = document.getElementById('iconMoon');
            const iconSun = document.getElementById('iconSun');
            const html = document.documentElement;
            const savedTheme = localStorage.getItem('theme') || 'light';
            html.setAttribute('data-bs-theme', savedTheme);
            iconMoon.style.display = savedTheme === 'dark' ? 'none' : 'inline';
            iconSun.style.display = savedTheme === 'dark' ? 'inline' : 'none';

            themeToggle.addEventListener('click', () => {
                const current = html.getAttribute('data-bs-theme');
                const next = current === 'dark' ? 'light' : 'dark';
                html.setAttribute('data-bs-theme', next);
                localStorage.setItem('theme', next);
                iconMoon.style.display = next === 'dark' ? 'none' : 'inline';
                iconSun.style.display = next === 'dark' ? 'inline' : 'none';
            });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index:9999">
        <div id="appToast" class="toast" role="alert">
            <div class="toast-header">
                <strong class="me-auto">Inventra</strong>
                <button type="button" class="btn-close" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body" id="appToastMessage"></div>
        </div>
    </div>

    <script>
            function showToast(message, isError = false) {
                const toastEl = document.getElementById('appToast');
                const toastBody = document.getElementById('appToastMessage');
                toastBody.textContent = message;
                toastEl.classList.toggle('text-bg-danger', isError);
                toastEl.classList.toggle('text-bg-success', !isError);
                const toast = new bootstrap.Toast(toastEl, { delay: 3000 });
                toast.show();
            }
    </script>
</body>
</html>