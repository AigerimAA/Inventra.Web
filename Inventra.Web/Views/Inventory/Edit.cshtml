    <div class="tab-pane fade" id="access">
        <div class="mb-3 d-flex justify-content-between align-items-center">
            <h5>Users with write access</h5>
            <div class="position-relative">
                <div class="d-flex gap-2" style="width:400px">
                    <input type="text" id="userSearchInput" class="form-control" placeholder="Search by name or email..." autocomplete="off" />
                    <button class="btn btn-primary btn-sm" onclick="addUser()">Add</button>
                </div>
                <ul id="userSearchDropdown" class="list-group position-absolute mt-1" style="z-index:1000;width:350px;display:none;"></ul>
            </div>
        </div>
        <div class="mb-2 d-flex gap-2">
            <span class="text-muted small me-2">Sort by:</span>
            <button class="btn btn-sm btn-outline-secondary" onclick="sortUsers('name')">Name</button>
            <button class="btn btn-sm btn-outline-secondary" onclick="sortUsers('email')">Email</button>
        </div>
        <table class="table table-hover table-sm" id="accessTable">
            <thead>
                <tr><th>Username</th><th>Email</th><th></th></tr>
            </thead>
