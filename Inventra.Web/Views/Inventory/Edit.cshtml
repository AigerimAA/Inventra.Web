@using Inventra.Application.DTOs
@model InventoryDto

@{
    ViewData["Title"] = "Edit - " + Model.Title;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Edit: @Model.Title</h2>
    <a asp-action="Details" asp-route-id="@Model.Id"
       class="btn btn-outline-secondary btn-sm">← Back</a>
</div>

<ul class="nav nav-tabs mb-4" id="editTabs">
    <li class="nav-item">
        <a class="nav-link active" data-bs-toggle="tab" href="#settings">Settings</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" data-bs-toggle="tab" href="#fields">Fields</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" data-bs-toggle="tab" href="#access">Access</a>
    </li>
</ul>

<div class="tab-content">

    <div class="tab-pane fade show active" id="settings">
        <div class="row">
            <div class="col-md-7">
                <form asp-action="EditSettings" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="Version" />

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">Title</label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CategoryId" class="form-label">Category</label>
                        <select asp-for="CategoryId" class="form-select"
                                asp-items="ViewBag.Categories">
                            <option value="0">-- Select category --</option>
                        </select>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="IsPublic" class="form-check-input" />
                        <label asp-for="IsPublic" class="form-check-label">
                            Public inventory
                        </label>
                    </div>

                    <button type="submit" class="btn btn-primary">Save Settings</button>
                </form>
            </div>
        </div>
    </div>

    <div class="tab-pane fade" id="fields">
        <form asp-action="EditFields" method="post">
            <input type="hidden" asp-for="Id" />

            <h5 class="mb-3">String Fields (up to 3)</h5>
            <div class="row mb-2">
                <div class="col-md-4">
                    <input asp-for="CustomString1Name" class="form-control"
                           placeholder="Field name (e.g. Model)" />
                </div>
                <div class="col-md-4">
                    <input asp-for="CustomString2Name" class="form-control"
                           placeholder="Field name" />
                </div>
                <div class="col-md-4">
                    <input asp-for="CustomString3Name" class="form-control"
                           placeholder="Field name" />
                </div>
            </div>

            <h5 class="mb-3 mt-4">Number Fields (up to 3)</h5>
            <div class="row mb-2">
                <div class="col-md-4">
                    <input asp-for="CustomInt1Name" class="form-control"
                           placeholder="Field name (e.g. Price)" />
                </div>
                <div class="col-md-4">
                    <input asp-for="CustomInt2Name" class="form-control"
                           placeholder="Field name" />
                </div>
                <div class="col-md-4">
                    <input asp-for="CustomInt3Name" class="form-control"
                           placeholder="Field name" />
                </div>
            </div>

            <h5 class="mb-3 mt-4">Text Fields (up to 3)</h5>
            <div class="row mb-2">
                <div class="col-md-4">
                    <input asp-for="CustomText1Name" class="form-control"
                           placeholder="Field name (e.g. Notes)" />
                </div>
                <div class="col-md-4">
                    <input asp-for="CustomText2Name" class="form-control"
                           placeholder="Field name" />
                </div>
                <div class="col-md-4">
                    <input asp-for="CustomText3Name" class="form-control"
                           placeholder="Field name" />
                </div>
            </div>

            <h5 class="mb-3 mt-4">Boolean Fields (up to 3)</h5>
            <div class="row mb-2">
                <div class="col-md-4">
                    <input asp-for="CustomBool1Name" class="form-control"
                           placeholder="Field name (e.g. Available)" />
                </div>
                <div class="col-md-4">
                    <input asp-for="CustomBool2Name" class="form-control"
                           placeholder="Field name" />
                </div>
                <div class="col-md-4">
                    <input asp-for="CustomBool3Name" class="form-control"
                           placeholder="Field name" />
                </div>
            </div>

            <h5 class="mb-3 mt-4">Link Fields (up to 3)</h5>
            <div class="row mb-2">
                <div class="col-md-4">
                    <input asp-for="CustomLink1Name" class="form-control"
                           placeholder="Field name (e.g. Datasheet)" />
                </div>
                <div class="col-md-4">
                    <input asp-for="CustomLink2Name" class="form-control"
                           placeholder="Field name" />
                </div>
                <div class="col-md-4">
                    <input asp-for="CustomLink3Name" class="form-control"
                           placeholder="Field name" />
                </div>
            </div>

            <button type="submit" class="btn btn-primary mt-3">Save Fields</button>
        </form>
    </div>

    <div class="tab-pane fade" id="access">
        <div class="alert alert-info">
            Access management coming soon.
        </div>
    </div>

</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}