                               placeholder="Field name, e.g. Model" />
                    </div>
                    <div class="col-md-auto d-flex align-items-end pb-1">
                        <div class="form-check mb-0">
                            <input asp-for="CustomString1Shown"
                                   class="form-check-input" />
                            <label asp-for="CustomString1Shown"
                                   class="form-check-label">
                                Show in table
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mb-3 border rounded p-3">
                <div class="row g-2 align-items-center">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">String Field 2</label>
                        <input asp-for="CustomString2Name"
                               class="form-control"
                               placeholder="Field name" />
                    </div>
                    <div class="col-md-auto d-flex align-items-end pb-1">
