</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        document.querySelectorAll('[data-bs-toggle="tab"]').forEach(tab => {
            tab.addEventListener('shown.bs.tab', e => {
                localStorage.setItem('editTab_@Model.Id',
                    e.target.getAttribute('href'));
            });
        });
        const saved = localStorage.getItem('editTab_@Model.Id');
        if (saved) {
            const tab = document.querySelector(`[href="${saved}"]`);
            if (tab) new bootstrap.Tab(tab).show();
        }
    </script>

    <script>
        let isDirty = false;
        let currentVersion = '@Convert.ToBase64String(Model.Version)';
        let debounceTimer = null;
        const inventoryId = parseInt('@Model.Id');
        const autoSaveUrl = '/Inventory/AutoSave';

        function showStatus(text, cssClass) {
            const el = document.getElementById('autoSaveStatus');
            el.textContent = text;
            el.className = 'ms-3 small ' + cssClass;
        }

        function collectFormData() {
            const get = id => document.getElementById(id)?.value ?? null;
            const getChecked = id => document.getElementById(id)?.checked ?? false;

            return {
                id: inventoryId,
                version: currentVersion,
                title: get('Title') ?? '',
                description: get('Description'),
                imageUrl: get('ImageUrl'),
                isPublic: getChecked('IsPublic'),
                categoryId: parseInt(get('CategoryId') ?? '0') || @Model.CategoryId,
                tags: [...document.querySelectorAll('.tag-item')].map(t => t.dataset.value),
                customString1Name: get('CustomString1Name'), customString1Shown: getChecked('CustomString1Shown'),
                customString2Name: get('CustomString2Name'), customString2Shown: getChecked('CustomString2Shown'),
                customString3Name: get('CustomString3Name'), customString3Shown: getChecked('CustomString3Shown'),
                customInt1Name: get('CustomInt1Name'), customInt1Shown: getChecked('CustomInt1Shown'),
                customInt2Name: get('CustomInt2Name'), customInt2Shown: getChecked('CustomInt2Shown'),
                customInt3Name: get('CustomInt3Name'), customInt3Shown: getChecked('CustomInt3Shown'),
                customText1Name: get('CustomText1Name'), customText1Shown: getChecked('CustomText1Shown'),
                customText2Name: get('CustomText2Name'), customText2Shown: getChecked('CustomText2Shown'),
                customText3Name: get('CustomText3Name'), customText3Shown: getChecked('CustomText3Shown'),
                customBool1Name: get('CustomBool1Name'), customBool1Shown: getChecked('CustomBool1Shown'),
                customBool2Name: get('CustomBool2Name'), customBool2Shown: getChecked('CustomBool2Shown'),
                customBool3Name: get('CustomBool3Name'), customBool3Shown: getChecked('CustomBool3Shown'),
                customLink1Name: get('CustomLink1Name'), customLink1Shown: getChecked('CustomLink1Shown'),
                customLink2Name: get('CustomLink2Name'), customLink2Shown: getChecked('CustomLink2Shown'),
                customLink3Name: get('CustomLink3Name'), customLink3Shown: getChecked('CustomLink3Shown'),
            };
        }

        async function autoSave() {
            if (!isDirty) return;
            showStatus('Saving...', 'text-warning');
            try {
                const response = await fetch(autoSaveUrl, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value },
                    body: JSON.stringify(collectFormData())
                });
                const data = await response.json();
                if (data.success) {
                    currentVersion = data.version;
                    isDirty = false;
                    showStatus('All changes saved', 'text-success');
                } else if (response.status === 409) {
                    showStatus('Conflict! Reload the page', 'text-danger');
                }
            } catch {
                showStatus('Save error', 'text-danger');
            }
        }

        function onFormChange() {
            isDirty = true;
            showStatus('Unsaved changes...', 'text-muted');
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(autoSave, 1000);
        }

        document.querySelectorAll('#settings input, #settings textarea, #settings select, #fields input')
            .forEach(el => el.addEventListener('input', onFormChange));
        document.querySelectorAll('#settings input[type=checkbox], #fields input[type=checkbox]')
            .forEach(el => el.addEventListener('change', onFormChange));

                document.getElementById('userSearchInput')?.addEventListener('input', function () {
            selectedUserId = null;
        });

        document.addEventListener('click', function(e) {
            if (!e.target.closest('#userSearchInput') && !e.target.closest('#userSearchDropdown'))
                document.getElementById('userSearchDropdown').style.display = 'none';
        });
    </script>

    <script>
        const inventoryIdForAccess = parseInt('@Model.Id');
        let accessUsers = [];
        let selectedUserId = null;

        async function loadAccessUsers() {
            const response = await fetch(`/Access/GetUsers?inventoryId=${inventoryIdForAccess}`);
            accessUsers = await response.json();
            renderAccessTable();
        }

        function renderAccessTable() {
            const tbody = document.getElementById('accessTableBody');
            if (accessUsers.length === 0) {
                tbody.innerHTML = '<tr><td colspan="3" class="text-muted text-center">No users with write access yet.</td></tr>';
                return;
            }
            tbody.innerHTML = accessUsers.map(u => `
                <tr>
                    <td>${u.userName}</td>
                    <td>${u.email}</td>
                    <td class="text-end"><button class="btn btn-sm btn-outline-danger" onclick="removeUser('${u.id}')">Remove</button></td>
                </tr>`).join('');
        }

        function sortUsers(by) {
            accessUsers.sort((a, b) => (a[by === 'name' ? 'userName' : 'email'] ?? '').localeCompare(b[by === 'name' ? 'userName' : 'email'] ?? ''));
            renderAccessTable();
        }

        document.getElementById('userSearchInput')?.addEventListener('input', async function () {
            selectedUserId = null;
            const query = this.value.trim();
            const dropdown = document.getElementById('userSearchDropdown');
            if (query.length < 2) { dropdown.style.display = 'none'; return; }
            const response = await fetch(`/Access/Search?query=${encodeURIComponent(query)}`);
            const users = await response.json();
            dropdown.innerHTML = users.map(u => `<li class="list-group-item list-group-item-action" style="cursor:pointer" onclick="selectUser('${u.id}','${u.userName}','${u.email}')">${u.userName} <small class="text-muted">${u.email}</small></li>`).join('');
            dropdown.style.display = users.length > 0 ? 'block' : 'none';
        });

        function selectUser(id, name, email) {
            selectedUserId = id;
            document.getElementById('userSearchInput').value = `${name} (${email})`;
            document.getElementById('userSearchDropdown').style.display = 'none';
        }

        async function addUser() {
            if (!selectedUserId) return alert('Please select a user from the dropdown');
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            const response = await fetch('/Access/Add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                body: JSON.stringify({ inventoryId: inventoryIdForAccess, userId: selectedUserId })
            });
            if (response.ok) {
                const data = await response.json();
                if (!accessUsers.some(u => u.id === selectedUserId)) {
                    accessUsers.push({ id: selectedUserId, userName: data.userName, email: data.email });
                    renderAccessTable();
                }
                document.getElementById('userSearchInput').value = '';
                selectedUserId = null;
            } else {
                const err = await response.json();
                alert(err.error ?? 'Error adding user');
            }
        }

        async function removeUser(userId) {
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            const response = await fetch('/Access/Remove', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                body: JSON.stringify({ inventoryId: inventoryIdForAccess, userId })
            });
            if (response.ok) {
                accessUsers = accessUsers.filter(u => u.id !== userId);
                renderAccessTable();
            }
        }

        document.addEventListener('click', function(e) {
            if (!e.target.closest('#userSearchInput') && !e.target.closest('#userSearchDropdown'))
                document.getElementById('userSearchDropdown').style.display = 'none';
        });

        document.querySelector('[href="#access"]')?.addEventListener('shown.bs.tab', loadAccessUsers);
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.15.0/Sortable.min.js"></script>
    <script>
        const inventoryIdForCustomId = @Model.Id;
        let customIdFormat = { inventoryId: inventoryIdForCustomId, elements: [] };

        const elementTypes = [
        { value: 'Fixed', label: 'Fixed', hint: 'A piece of unchanging text. E.g., you can use Unicode emoji.' },
        { value: 'Random20', label: '20-bit random', hint: 'A random value. E.g., format as 5-digit hex (X5).' },
        { value: 'Random32', label: '32-bit random', hint: 'A random value. E.g., format as 8-digit hex (X8).' },
        { value: 'Random6Digits', label: '6-digit random', hint: 'A random 6-digit number.' },
        { value: 'Random9Digits', label: '9-digit random', hint: 'A random 9-digit number.' },
        { value: 'Guid', label: 'GUID', hint: 'A globally unique identifier.' },
        { value: 'DateTime', label: 'Date/time', hint: 'Item creation date. E.g., yyyy, MM, dd.' },
        { value: 'Sequence', label: 'Sequence', hint: 'Sequential index. E.g., D3 for 3-digit with leading zeros.' }
        ];

        async function loadCustomIdFormat() {
        const response = await fetch(`/Inventory/GetCustomIdFormat?inventoryId=${inventoryIdForCustomId}`);
        const data = await response.json();
        customIdFormat = data;
        renderElements();
        await updatePreview();
        }

        function renderElements() {
        const container = document.getElementById('customIdElements');
        container.innerHTML = '';

        if (customIdFormat.elements.length === 0) {
        container.innerHTML = '<p class="text-muted">No elements yet. Click "Add element" to start.</p>';
        return;
        }

        customIdFormat.elements.forEach((el, index) => {
        const div = document.createElement('div');
        div.className = 'card mb-2 custom-id-element';
        div.dataset.index = index;
        div.innerHTML = `
        <div class="card-body py-2 px-3">
        <div class="row g-2 align-items-center">
        <div class="col-auto">
        <span class="drag-handle" style="cursor:grab;">↕</span>
        </div>
        <div class="col-md-4">
        <select class="form-select form-select-sm" onchange="updateElementType(${index}, this.value)">
        ${elementTypes.map(t => `<option value="${t.value}" ${el.elementType === t.value ? 'selected' : ''}>${t.label}</option>`).join('')}
        </select>
        <small class="text-muted">${elementTypes.find(t => t.value === el.elementType)?.hint ?? ''}</small>
        </div>
        <div class="col-md-4">
        ${el.elementType === 'Fixed'
        ? `<input type="text" class="form-control form-control-sm" placeholder="Fixed text..." value="${el.fixedValue ?? ''}" onchange="updateFixedValue(${index}, this.value)" />`
        : `<input type="text" class="form-control form-control-sm" placeholder="Format (e.g. D3, X5, yyyy)..." value="${el.formatString ?? ''}" onchange="updateFormatString(${index}, this.value)" />`
        }
        </div>
        <div class="col-auto ms-auto">
        <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeElement(${index})">✕</button>
        </div>
        </div>
        </div>`;
        container.appendChild(div);
        });

        Sortable.create(container, {
        handle: '.drag-handle',
        animation: 150,
        onEnd: function(evt) {
        const moved = customIdFormat.elements.splice(evt.oldIndex, 1)[0];
        customIdFormat.elements.splice(evt.newIndex, 0, moved);
        customIdFormat.elements.forEach((el, i) => el.sortOrder = i);
        renderElements();
        updatePreview();
        }
        });
        }

        function addElement() {
        customIdFormat.elements.push({
        elementType: 'Fixed',
        fixedValue: '',
        formatString: '',
        sortOrder: customIdFormat.elements.length
        });
        renderElements();
        updatePreview();
        saveCustomIdFormat();
        }

        function removeElement(index) {
        customIdFormat.elements.splice(index, 1);
        customIdFormat.elements.forEach((el, i) => el.sortOrder = i);
        renderElements();
        updatePreview();
        saveCustomIdFormat();
        }

        function updateElementType(index, value) {
        customIdFormat.elements[index].elementType = value;
        customIdFormat.elements[index].fixedValue = '';
        customIdFormat.elements[index].formatString = '';
        renderElements();
        updatePreview();
        saveCustomIdFormat();
        }

        function updateFixedValue(index, value) {
        customIdFormat.elements[index].fixedValue = value;
        updatePreview();
        saveCustomIdFormat();
        }

        function updateFormatString(index, value) {
        customIdFormat.elements[index].formatString = value;
        updatePreview();
        saveCustomIdFormat();
        }

        async function updatePreview() {
        try {
        const response = await fetch(`/Inventory/PreviewCustomId?inventoryId=${inventoryIdForCustomId}`);
        const data = await response.json();
        document.getElementById('customIdPreview').textContent = data.preview;
        } catch {
        document.getElementById('customIdPreview').textContent = 'Preview unavailable';
        }
        }

        async function saveCustomIdFormat() {
        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        await fetch('/Inventory/SaveCustomIdFormat', {
        method: 'POST',
        headers: {
        'Content-Type': 'application/json',
        'RequestVerificationToken': token
        },
        body: JSON.stringify(customIdFormat)
        });
        }

        document.querySelector('[href="#customid"]')?.addEventListener('shown.bs.tab', loadCustomIdFormat);
    </script>
}