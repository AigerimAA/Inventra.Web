@using Inventra.Application.DTOs
@model InventoryDto

@{
    ViewData["Title"] = Model.Title;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-1">@Model.Title</h2>
        <span class="inv-badge">@Model.CategoryName</span>
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <div class="mt-2">
                <img src="@Model.ImageUrl" style="max-height:200px; border-radius:8px;" />
            </div>
        }
    </div>
    @if (User.Identity?.IsAuthenticated == true &&
         (Model.OwnerId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value
          || User.IsInRole("Admin")))
    {
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id"
               class="btn btn-outline-primary btn-sm">@L["Edit"]</a>
            
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                <button type="submit" class="btn btn-outline-danger btn-sm"
                        onclick="return confirm('Delete this inventory?')">
                    @L["Delete"]
                </button>
            </form>
        </div>
    }
</div>

<ul class="nav nav-tabs mb-3" id="inventoryTabs">
    <li class="nav-item">
        <a class="nav-link active" data-bs-toggle="tab" href="#items">@L["Items"]</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" data-bs-toggle="tab" href="#discussion">@L["Discussion"]</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" data-bs-toggle="tab" href="#settings">@L["Settings"]</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" data-bs-toggle="tab" href="#stats">@L["Stats"]</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" data-bs-toggle="tab" href="#export">@L["Export"]</a>
    </li>
</ul>

<style>
.inv-card { border-radius: 12px; overflow: hidden; border: 0.5px solid var(--bs-border-color); margin-bottom: 16px; }
.inv-card-header { background: #0097a7; padding: 14px 20px; display: flex; justify-content: space-between; align-items: center; }
.inv-card-header span { color: white; font-size: 15px; font-weight: 500; }
.inv-table { width: 100%; border-collapse: collapse; }
.inv-table thead tr { border-bottom: 0.5px solid var(--bs-border-color); }
.inv-table thead th { padding: 10px 16px; font-size: 12px; font-weight: 500; color: var(--bs-secondary-color); text-transform: uppercase; letter-spacing: 0.05em; }
.inv-table tbody tr { border-bottom: 0.5px solid var(--bs-border-color); transition: background 0.15s; cursor: pointer; }
.inv-table tbody tr:hover { background: rgba(0,151,167,0.06); }
.inv-table tbody tr:last-child { border-bottom: none; }
.inv-table tbody td { padding: 12px 16px; font-size: 14px; }
.inv-badge { display: inline-block; background: rgba(0,151,167,0.12); color: #0097a7; font-size: 12px; padding: 2px 8px; border-radius: 20px; font-weight: 500; }
.inv-count { font-weight: 500; color: #0097a7; }
.inv-table { table-layout: fixed; width: 100%; }
.inv-table th, .inv-table td { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

</style>

<div class="tab-content">
    <div class="tab-pane fade show active" id="items">
    <div class="d-flex justify-content-end mb-2 gap-2">
    
    @if (User.Identity?.IsAuthenticated == true &&
     (Model.IsPublic ||
      Model.OwnerId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ||
      User.IsInRole("Admin")))
{
    <a asp-controller="Item" asp-action="Create"
       asp-route-inventoryId="@Model.Id"
       class="btn btn-primary btn-sm">+ Add Item</a>
}
 </div>   

    <div class="inv-card">
        <div class="inv-card-header">
            <span>@L["Items"] (@((ViewBag.Items as IEnumerable<ItemDto>)?.Count() ?? 0))</span>
        </div>
        <div class="table-responsive">
            <table class="inv-table">
                <colgroup>
                    <col style="width: 140px;" />
                    @if (Model.CustomString1Name != null) { <col style="width: 120px;" /> }
                    @if (Model.CustomString2Name != null) { <col style="width: 120px;" /> }
                    @if (Model.CustomString3Name != null) { <col style="width: 120px;" /> }
                    @if (Model.CustomInt1Name != null) { <col style="width: 100px;" /> }
                    @if (Model.CustomInt2Name != null) { <col style="width: 100px;" /> }
                    @if (Model.CustomInt3Name != null) { <col style="width: 100px;" /> }
                    @if (Model.CustomText1Name != null) { <col style="width: 150px;" /> }
                    @if (Model.CustomBool1Name != null) { <col style="width: 80px;" /> }
                    @if (Model.CustomLink1Name != null) { <col style="width: 80px;" /> }
                    <col style="width: 120px;" />
                    <col style="width: 70px;" />
                </colgroup>
                <thead>
                    <tr>
                        <th>Custom ID</th>
                        @if (Model.CustomString1Name != null) { <th>@Model.CustomString1Name</th> }
                        @if (Model.CustomString2Name != null) { <th>@Model.CustomString2Name</th> }
                        @if (Model.CustomString3Name != null) { <th>@Model.CustomString3Name</th> }
                        @if (Model.CustomInt1Name != null) { <th class="text-end">@Model.CustomInt1Name</th> }
                        @if (Model.CustomInt2Name != null) { <th class="text-end">@Model.CustomInt2Name</th> }
                        @if (Model.CustomInt3Name != null) { <th class="text-end">@Model.CustomInt3Name</th> }
                        @if (Model.CustomText1Name != null) { <th>@Model.CustomText1Name</th> }
                        @if (Model.CustomBool1Name != null) { <th>@Model.CustomBool1Name</th> }
                        @if (Model.CustomLink1Name != null) { <th>@Model.CustomLink1Name</th> }
                        <th>Created By</th>
                        <th class="text-end">Likes</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        var items = ViewBag.Items as IEnumerable<ItemDto>;
                    }
                    @if (items == null || !items.Any())
                    {
                        <tr>
                            <td colspan="20" class="text-center text-muted" style="padding:24px;">@L["NoItemsYet"]</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in items)
                        {
                            <tr onclick="window.location='/Item/Details/@item.Id'">
                                <td class="inv-count">@item.CustomId</td>
                                @if (Model.CustomString1Name != null) { <td>@item.CustomString1Value</td> }
                                @if (Model.CustomString2Name != null) { <td>@item.CustomString2Value</td> }
                                @if (Model.CustomString3Name != null) { <td>@item.CustomString3Value</td> }
                                @if (Model.CustomInt1Name != null) { <td class="text-end">@(item.CustomInt1Value.HasValue ? (item.CustomInt1Value.Value % 1 == 0 ? ((int)item.CustomInt1Value.Value).ToString() : item.CustomInt1Value.Value.ToString("N2")) : "")</td> }
                                @if (Model.CustomInt2Name != null) { <td class="text-end">@(item.CustomInt2Value.HasValue ? (item.CustomInt2Value.Value % 1 == 0 ? ((int)item.CustomInt2Value.Value).ToString() : item.CustomInt2Value.Value.ToString("N2")) : "")</td> }
                                @if (Model.CustomInt3Name != null) { <td class="text-end">@(item.CustomInt3Value.HasValue ? (item.CustomInt3Value.Value % 1 == 0 ? ((int)item.CustomInt3Value.Value).ToString() : item.CustomInt3Value.Value.ToString("N2")) : "")</td> }
                                @if (Model.CustomText1Name != null) { <td>@item.CustomText1Value</td> }
                                @if (Model.CustomBool1Name != null) { <td>@(item.CustomBool1Value == true ? "✓" : "✗")</td> }
                                @if (Model.CustomLink1Name != null)
                                {
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.CustomLink1Value))
                                        {
                                            <a href="@item.CustomLink1Value" target="_blank">Link</a>
                                        }
                                    </td>
                                }
                                <td style="color:var(--bs-secondary-color);">@item.CreatedByName</td>
                                <td class="text-end">
                                    @if (User.Identity?.IsAuthenticated == true)
                                    {
                                        <form asp-controller="Like" asp-action="Toggle" method="post" class="d-inline">
                                            <input type="hidden" name="itemId" value="@item.Id" />
                                            <input type="hidden" name="inventoryId" value="@Model.Id" />
                                            <button type="submit" class="btn btn-sm btn-link p-0 text-decoration-none"
                                                    title="@item.LikesCount likes">
                                                ❤️ @item.LikesCount
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span>❤️ @item.LikesCount</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>


    @{
            var itemsWithPhotos = items?.Where(i => !string.IsNullOrEmpty(i.ImageUrl)).ToList();
        }
        @if (itemsWithPhotos != null && itemsWithPhotos.Any())
        {
            <div class="mt-3">
                <h6 style="color:#0097a7; font-size:12px; text-transform:uppercase; letter-spacing:0.05em;">Photos</h6>
                <div style="display:flex; flex-wrap:wrap; gap:12px;">
                    @foreach (var item in itemsWithPhotos)
                    {
                        <div style="cursor:pointer;" onclick="window.location='/Item/Details/@item.Id'">
                            <img src="@item.ImageUrl" style="height:120px; width:120px; object-fit:cover; border-radius:8px;" />
                            <div style="font-size:12px; color:#0097a7; text-align:center; margin-top:4px;">@item.CustomId</div>
                        </div>
                    }
                </div>
            </div>
        }

</div>

    <div class="tab-pane fade" id="discussion">
    <div class="inv-card">
        <div class="inv-card-header">
            <span>@L["Discussion"]</span>
        </div>
        <div id="chatMessages"
             style="height:400px; overflow-y:auto; padding:16px;">
            <p class="text-muted text-center mt-5" id="noMessages">
                No messages yet. Be the first to write! 💬
            </p>
        </div>
    </div>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <form asp-controller="Comment" asp-action="Create" method="post" id="commentForm">
            <input type="hidden" name="inventoryId" value="@Model.Id" />

            <div style="display:flex; gap:4px; padding:8px; border:0.5px solid var(--bs-border-color); border-bottom:none; border-radius:8px 8px 0 0; background:var(--bs-body-bg);">
                <button type="button" onclick="formatText('bold')" title="Bold"
                        style="border:0.5px solid var(--bs-border-color); background:transparent; border-radius:4px; padding:4px 8px; cursor:pointer; font-weight:700; color:var(--bs-body-color);">B</button>
                <button type="button" onclick="formatText('italic')" title="Italic"
                        style="border:0.5px solid var(--bs-border-color); background:transparent; border-radius:4px; padding:4px 8px; cursor:pointer; font-style:italic; color:var(--bs-body-color);">I</button>
                <button type="button" onclick="formatText('underline')" title="Underline"
                        style="border:0.5px solid var(--bs-border-color); background:transparent; border-radius:4px; padding:4px 8px; cursor:pointer; text-decoration:underline; color:var(--bs-body-color);">U</button>
                <span style="width:1px; background:var(--bs-border-color); margin:2px 4px;"></span>
                @foreach (var emoji in new[] { "😊", "👍", "❤️", "😂", "🎉", "🔥" })
                {
                    <button type="button" onclick="insertEmoji('@emoji')" title="@emoji"
                            style="border:none; background:transparent; border-radius:4px; padding:4px 6px; cursor:pointer; font-size:16px;">@emoji</button>
                }
            </div>

            <div style="display:flex; gap:0;">
                <div id="messageInput" contenteditable="true"
                     style="flex:1; min-height:42px; padding:10px 14px; border:0.5px solid var(--bs-border-color); border-right:none; border-radius:0 0 0 8px; outline:none; background:var(--bs-body-bg); color:var(--bs-body-color);"
                     data-placeholder="Write a message..."></div>
                <button type="submit" class="btn btn-primary"
                        style="border-radius:0 0 8px 0; padding:10px 24px;">Send</button>
            </div>
            <input type="hidden" name="content" id="hiddenContent" />
        </form>

            <style>
                #messageInput:empty:before {
                    content: attr(data-placeholder);
                    color: var(--bs-secondary-color);
                }
            </style>

            <script>
                document.getElementById('commentForm').addEventListener('submit', function() {
                    document.getElementById('hiddenContent').value = 
                        document.getElementById('messageInput').innerHTML;
                });

                function formatText(command) {
                    document.getElementById('messageInput').focus();
                    document.execCommand(command, false, null);
                }

                function insertEmoji(emoji) {
                    const input = document.getElementById('messageInput');
                    input.focus();
                    document.execCommand('insertText', false, emoji);
                }
            </script>
        }
        else
        {
            <p class="text-muted mt-2">
                <a asp-controller="Account" asp-action="Login">@L["Login"]</a> to join discussion.
            </p>
        }
    </div>

    <div class="tab-pane fade" id="settings">
    <div class="inv-card" style="max-width:700px; margin-top:8px;">
        <div class="inv-card-header">
            <span>@L["Settings"]</span>
        </div>
        <table class="inv-table">
            <tbody>
                <tr>
                    <td style="width:140px; color:var(--bs-secondary-color); font-size:12px; text-transform:uppercase; letter-spacing:0.05em;">@L["Category"]</td>
                    <td style="font-weight:500;">@Model.CategoryName</td>
                </tr>
                <tr>
                    <td style="color:var(--bs-secondary-color); font-size:12px; text-transform:uppercase; letter-spacing:0.05em;">@L["Creator"]</td>
                    <td style="font-weight:500;">@Model.OwnerName</td>
                </tr>
                <tr>
                    <td style="color:var(--bs-secondary-color); font-size:12px; text-transform:uppercase; letter-spacing:0.05em;">@L["Description"]</td>
                    <td>@Model.Description</td>
                </tr>
                <tr>
                    <td style="color:var(--bs-secondary-color); font-size:12px; text-transform:uppercase; letter-spacing:0.05em;">@L["Access"]</td>
                    <td><span class="inv-badge">@(Model.IsPublic ? "Public" : "Private")</span></td>
                </tr>
                <tr>
                    <td style="color:var(--bs-secondary-color); font-size:12px; text-transform:uppercase; letter-spacing:0.05em;">@L["Tags"]</td>
                    <td>
                        @foreach (var tag in Model.Tags)
                        {
                            <span class="inv-badge me-1">@tag</span>
                        }
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>


<div class="tab-pane fade" id="stats">
    @{
        var stats = ViewBag.Stats as Inventra.Application.DTOs.InventoryStatsDto;
        var inv = Model;
    }

    <div class="inv-card" style="max-width:700px; margin-top:8px;">
        <div class="inv-card-header">
            <span>@L["Stats"]</span>
        </div>
        <table class="inv-table">
            <tbody>
                <tr>
                    <td style="width:180px; color:var(--bs-secondary-color); font-size:12px; text-transform:uppercase; letter-spacing:0.05em;">@L["TotalItems"]</td>
                    <td><span class="inv-count" style="font-size:16px;">@stats?.TotalItems</span></td>
                </tr>
            </tbody>
        </table>
    </div>

    @if (stats?.TotalItems > 0)
    {
        @if (inv.CustomInt1Name != null && stats.Int1Avg.HasValue)
        {
            <div class="inv-card" style="max-width:700px;">
                <div class="inv-card-header"><span>@inv.CustomInt1Name</span></div>
                <table class="inv-table">
                    <tbody>
                        <tr><td style="width:180px; color:var(--bs-secondary-color); font-size:12px; text-transform:uppercase; letter-spacing:0.05em;">@L["Average"]</td><td class="inv-count">@(stats.Int1Avg.HasValue ? (stats.Int1Avg.Value % 1 == 0 ? ((int)stats.Int1Avg.Value).ToString() : stats.Int1Avg.Value.ToString("N2")) : "")</td></tr>
                        <tr><td style="color:var(--bs-secondary-color); font-size:12px; text-transform:uppercase; letter-spacing:0.05em;">@L["Min"]</td><td class="inv-count">@(stats.Int1Min.HasValue ? (stats.Int1Min.Value % 1 == 0 ? ((int)stats.Int1Min.Value).ToString() : stats.Int1Min.Value.ToString("N2")) : "")</td></tr>
                        <tr><td style="color:var(--bs-secondary-color); font-size:12px; text-transform:uppercase; letter-spacing:0.05em;">@L["Max"]</td><td class="inv-count">@(stats.Int1Max.HasValue ? (stats.Int1Max.Value % 1 == 0 ? ((int)stats.Int1Max.Value).ToString() : stats.Int1Max.Value.ToString("N2")) : "")</td></tr>
                    </tbody>
                </table>
            </div>
        }
        @if (inv.CustomInt2Name != null && stats.Int2Avg.HasValue)
        {
            <div class="inv-card" style="max-width:700px;">
                <div class="inv-card-header"><span>@inv.CustomInt2Name</span></div>
                <table class="inv-table">
                    <tbody>
                        <tr><td style="width:180px; color:var(--bs-secondary-color); font-size:12px; text-transform:uppercase; letter-spacing:0.05em;">@L["Average"]</td><td class="inv-count">@(stats.Int2Avg.HasValue ? (stats.Int2Avg.Value % 1 == 0 ? ((int)stats.Int2Avg.Value).ToString() : stats.Int2Avg.Value.ToString("N2")) : "")</td></tr>
                        <tr><td style="color:var(--bs-secondary-color); font-size:12px; text-transform:uppercase; letter-spacing:0.05em;">@L["Min"]</td><td class="inv-count">@(stats.Int2Min.HasValue ? (stats.Int2Min.Value % 1 == 0 ? ((int)stats.Int2Min.Value).ToString() : stats.Int2Min.Value.ToString("N2")) : "")</td></tr>
                        <tr><td style="color:var(--bs-secondary-color); font-size:12px; text-transform:uppercase; letter-spacing:0.05em;">@L["Max"]</td><td class="inv-count">@(stats.Int2Max.HasValue ? (stats.Int2Max.Value % 1 == 0 ? ((int)stats.Int2Max.Value).ToString() : stats.Int2Max.Value.ToString("N2")) : "")</td></tr>
                    </tbody>
                </table>
            </div>
        }
        @if (inv.CustomInt3Name != null && stats.Int3Avg.HasValue)
        {
            <div class="inv-card" style="max-width:700px;">
                <div class="inv-card-header"><span>@inv.CustomInt3Name</span></div>
                <table class="inv-table">
                    <tbody>
                        <tr><td style="width:180px; color:var(--bs-secondary-color); font-size:12px; text-transform:uppercase; letter-spacing:0.05em;">@L["Average"]</td><td class="inv-count">@(stats.Int3Avg.HasValue ? (stats.Int3Avg.Value % 1 == 0 ? ((int)stats.Int3Avg.Value).ToString() : stats.Int3Avg.Value.ToString("N2")) : "")</td></tr>
                        <tr><td style="color:var(--bs-secondary-color); font-size:12px; text-transform:uppercase; letter-spacing:0.05em;">@L["Min"]</td><td class="inv-count">@(stats.Int3Min.HasValue ? (stats.Int3Min.Value % 1 == 0 ? ((int)stats.Int3Min.Value).ToString() : stats.Int3Min.Value.ToString("N2")) : "")</td></tr>
                        <tr><td style="color:var(--bs-secondary-color); font-size:12px; text-transform:uppercase; letter-spacing:0.05em;">@L["Max"]</td><td class="inv-count">@(stats.Int3Max.HasValue ? (stats.Int3Max.Value % 1 == 0 ? ((int)stats.Int3Max.Value).ToString() : stats.Int3Max.Value.ToString("N2")) : "")</td></tr>
                    </tbody>
                </table>
            </div>
        }
        @if (inv.CustomString1Name != null && stats.String1TopValue != null)
        {
            <div class="inv-card" style="max-width:700px;">
                <div class="inv-card-header"><span>@inv.CustomString1Name — @L["MostFrequent"]</span></div>
                <table class="inv-table">
                    <tbody>
                        <tr><td><span class="inv-badge">@stats.String1TopValue</span></td><td class="inv-count">@stats.String1TopCount times</td></tr>
                    </tbody>
                </table>
            </div>
        }
        @if (inv.CustomString2Name != null && stats.String2TopValue != null)
        {
            <div class="inv-card" style="max-width:700px;">
                <div class="inv-card-header"><span>@inv.CustomString2Name — @L["MostFrequent"]</span></div>
                <table class="inv-table">
                    <tbody>
                        <tr><td><span class="inv-badge">@stats.String2TopValue</span></td><td class="inv-count">@stats.String2TopCount times</td></tr>
                    </tbody>
                </table>
            </div>
        }
        @if (inv.CustomString3Name != null && stats.String3TopValue != null)
        {
            <div class="inv-card" style="max-width:700px;">
                <div class="inv-card-header"><span>@inv.CustomString3Name — @L["MostFrequent"]</span></div>
                <table class="inv-table">
                    <tbody>
                        <tr><td><span class="inv-badge">@stats.String3TopValue</span></td><td class="inv-count">@stats.String3TopCount times</td></tr>
                    </tbody>
                </table>
            </div>
        }
    }
    else
    {
        <div class="alert alert-info mt-3">@L["NoItemsYet"]</div>
    }
    </div>

    <div class="tab-pane fade" id="export">
        <div class="inv-card" style="max-width:400px; margin-top:8px;">
            <div class="inv-card-header">
                <span>@L["Export"]</span>

            </div>
            <div style="padding:20px;">
                <p style="color:var(--bs-body-color); margin-bottom:16px;">
                    @L["ExportDescription"]
                </p>
                <a asp-controller="Inventory" asp-action="ExportToCsv" asp-route-id="@Model.Id"
                   class="btn btn-primary">
                    <i class="bi bi-download"></i> @L["DownloadCsv"]
                </a>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>
    <script>
        const inventoryId = parseInt('@Model.Id');

        async function loadComments() {
            const response = await fetch(`/Comment/GetComments?inventoryId=${inventoryId}`);
            const comments = await response.json();
            const container = document.getElementById('chatMessages');
            container.innerHTML = '';
            if (comments.length === 0) {
                container.innerHTML = '<p class="text-muted text-center mt-5">No messages yet. Be the first to write!</p>';
            } else {
                comments.forEach(c => appendMessage(c.authorName, c.content, c.createdAt));
            }
            container.scrollTop = container.scrollHeight;
        }

        function appendMessage(author, content, time) {
            const container = document.getElementById('chatMessages');
            const div = document.createElement('div');
            div.className = 'mb-2';
            div.innerHTML = `<strong>${author}</strong> <small class="text-muted">${time}</small><br>${content}`;
            container.appendChild(div);
            container.scrollTop = container.scrollHeight;
        }

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .build();

        connection.on("ReceiveMessage", (user, message, timestamp) => {
            appendMessage(user, message, timestamp);
        });

        connection.start().then(() => {
            connection.invoke("JoinInventory", inventoryId);
            loadComments();
        });

        document.querySelectorAll('[data-bs-toggle="tab"]').forEach(tab => {
            tab.addEventListener('shown.bs.tab', e => {
                localStorage.setItem('activeTab_' + inventoryId, e.target.getAttribute('href'));
            });
        });

        const savedTab = localStorage.getItem('activeTab_' + inventoryId);
        if (savedTab) {
            const tab = document.querySelector(`[href="${savedTab}"]`);
            if (tab) new bootstrap.Tab(tab).show();
        }
    </script>
}