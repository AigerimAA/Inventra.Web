@using Inventra.Application.DTOs
@using Inventra.Web.Models
@model ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>My Profile</h2>
    <span class="text-muted">@User.Identity?.Name</span>
</div>

<div class="mb-5">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h4>My Inventories (@Model.OwnedInventories.Count())</h4>
        <a asp-controller="Inventory" asp-action="Create" class="btn btn-primary btn-sm">+ New Inventory</a>
    </div>
    <table class="table table-hover table-sm">
        <thead>
            <tr>
                <th>Title</th>
                <th>Category</th>
                <th class="text-end">Items</th>
                <th>Access</th>
                <th>Tags</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.OwnedInventories.Any())
            {
                <tr><td colspan="5" class="text-center text-muted">No inventories yet.</td></tr>
            }
            else
            {
                @foreach (var inv in Model.OwnedInventories)
                {
                    <tr style="cursor:pointer" onclick="window.location='/Inventory/Details/@inv.Id'">
                        <td>@inv.Title</td>
                        <td>@inv.CategoryName</td>
                        <td class="text-end">@inv.ItemsCount</td>
                        <td>@(inv.IsPublic ? "Public" : "Private")</td>
                        <td>@foreach (var tag in inv.Tags) {
                            <span class="badge bg-secondary me-1">@tag</span>
                        }
                    </td>
                </tr>
            }
        }
    </tbody>
</table>
</div>

<div>
    <h4 class="mb-2">Inventories with Write Access (@Model.AccessibleInventories.Count())</h4>
    <table class="table table-hover table-sm">
        <thead>
            <tr>
                <th>Title</th>
                <th>Category</th>
                <th>Creator</th>
                <th class="text-end">Items</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.AccessibleInventories.Any())
            {
                <tr><td colspan="4" class="text-center text-muted">No inventories with write access.</td></tr>
            }
            else
            {
                @foreach (var inv in Model.AccessibleInventories)
                {
                    <tr style="cursor:pointer" onclick="window.location='/Inventory/Details/@inv.Id'">
                        <td>@inv.Title</td>
                        <td>@inv.CategoryName</td>
                        <td>@inv.OwnerName</td>
                        <td class="text-end">@inv.ItemsCount</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
