@using Inventra.Application.Items.Commands.CreateItem
@using Inventra.Application.DTOs
@model CreateItemCommand

@{
    ViewData["Title"] = "Add Item";
    var inventory = ViewBag.Inventory as InventoryDto;
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <h2 class="mb-1">Add Item</h2>
        <p class="text-muted mb-4">
            to <a asp-controller="Inventory" asp-action="Details"
                  asp-route-id="@inventory?.Id">@inventory?.Title</a>
        </p>

        <form asp-action="Create" method="post">
            <input type="hidden" asp-for="InventoryId" value="@inventory?.Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            @if (!string.IsNullOrEmpty(inventory?.CustomString1Name))
            {
                <div class="mb-3"><label class="form-label">@inventory!.CustomString1Name</label><input asp-for="CustomString1Value" class="form-control" /></div>
            }
            @if (!string.IsNullOrEmpty(inventory?.CustomString2Name))
            {
                <div class="mb-3"><label class="form-label">@inventory!.CustomString2Name</label><input asp-for="CustomString2Value" class="form-control" /></div>
            }
            @if (!string.IsNullOrEmpty(inventory?.CustomString3Name))
            {
                <div class="mb-3"><label class="form-label">@inventory!.CustomString3Name</label><input asp-for="CustomString3Value" class="form-control" /></div>
            }
            @if (!string.IsNullOrEmpty(inventory?.CustomInt1Name))
            {
                <div class="mb-3"><label class="form-label">@inventory!.CustomInt1Name</label><input asp-for="CustomInt1Value" class="form-control" type="number" step="any" /></div>
            }
            @if (!string.IsNullOrEmpty(inventory?.CustomInt2Name))
            {
                <div class="mb-3"><label class="form-label">@inventory!.CustomInt2Name</label><input asp-for="CustomInt2Value" class="form-control" type="number" step="any" /></div>
            }
            @if (!string.IsNullOrEmpty(inventory?.CustomInt3Name))
            {
                <div class="mb-3"><label class="form-label">@inventory!.CustomInt3Name</label><input asp-for="CustomInt3Value" class="form-control" type="number" step="any" /></div>
            }
            @if (!string.IsNullOrEmpty(inventory?.CustomText1Name))
            {
                <div class="mb-3"><label class="form-label">@inventory!.CustomText1Name</label><textarea asp-for="CustomText1Value" class="form-control" rows="3"></textarea></div>
            }
            @if (!string.IsNullOrEmpty(inventory?.CustomBool1Name))
            {
                <div class="mb-3 form-check"><input type="checkbox" class="form-check-input" name="CustomBool1Value" value="true" @(Model?.CustomBool1Value == true ? "checked" : "") /><input type="hidden" name="CustomBool1Value" value="false" /><label class="form-check-label">@inventory!.CustomBool1Name</label></div>
            }
            @if (!string.IsNullOrEmpty(inventory?.CustomLink1Name))
            {
                <div class="mb-3"><label class="form-label">@inventory!.CustomLink1Name</label><input asp-for="CustomLink1Value" class="form-control" placeholder="https://..." /></div>
            }

            @if (string.IsNullOrEmpty(inventory?.CustomString1Name) && string.IsNullOrEmpty(inventory?.CustomInt1Name) && string.IsNullOrEmpty(inventory?.CustomText1Name) && string.IsNullOrEmpty(inventory?.CustomBool1Name) && string.IsNullOrEmpty(inventory?.CustomLink1Name))
            {
                <div class="alert alert-info">This inventory has no custom fields yet. <a asp-controller="Inventory" asp-action="Edit" asp-route-id="@inventory?.Id">Add fields</a> first.</div>
            }

            @if (!string.IsNullOrEmpty(inventory?.CustomString1Name) || !string.IsNullOrEmpty(inventory?.CustomInt1Name) || !string.IsNullOrEmpty(inventory?.CustomText1Name) || !string.IsNullOrEmpty(inventory?.CustomBool1Name) || !string.IsNullOrEmpty(inventory?.CustomLink1Name))
            {
                <div class="mb-3"><label class="form-label">Photo</label><input type="file" id="itemImageUpload" class="form-control" accept="image/*" /><input type="hidden" name="ImageUrl" id="ItemImageUrl" /></div>
            }

            <div class="d-flex gap-2 mt-3">
                <button type="submit" id="saveBtn" class="btn btn-primary">Add Item</button>
                <a asp-controller="Inventory" asp-action="Details"
                   asp-route-id="@inventory?.Id"
                   class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        document.getElementById('itemImageUpload')?.addEventListener('change', async function() {
            const file = this.files[0];
            if (!file) return;

            const saveBtn = document.getElementById('saveBtn');
            saveBtn.disabled = true;
            saveBtn.textContent = 'Uploading photo...';

            const formData = new FormData();
            formData.append('file', file);
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            const response = await fetch('/Item/UploadImage', {
                method: 'POST',
                headers: { 'RequestVerificationToken': token },
                body: formData
            });

            if (response.ok) {
                const data = await response.json();
                document.getElementById('ItemImageUrl').value = data.url;
                saveBtn.textContent = 'Add Item';
                saveBtn.disabled = false;
            } else {
                saveBtn.textContent = 'Add Item';
                saveBtn.disabled = false;
                showToast('Photo upload failed', true);
            }
        });
    </script>
}
