@using Inventra.Web.Models
@model EditItemViewModel

@{
    ViewData["Title"] = "Edit Item";
    var inventory = Model.Inventory;
    var cmd = Model.Command;
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="mb-1">Edit Item</h2>
                <p class="text-muted mb-0">in <a asp-controller="Inventory" asp-action="Details" asp-route-id="@inventory.Id">@inventory.Title</a></p>
            </div>
            <a asp-action="Details" asp-route-id="@cmd.Id" class="btn btn-outline-secondary btn-sm">← Back</a>
        </div>

        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Command.Id" />
            <input type="hidden" asp-for="Command.InventoryId" />
            <input type="hidden" name="VersionString" value="@Model.VersionString" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            @if (!string.IsNullOrEmpty(inventory.CustomString1Name))
            {
                <div class="mb-3"><label class="form-label">@inventory.CustomString1Name</label><input asp-for="Command.CustomString1Value" class="form-control" /></div>
            }
            @if (!string.IsNullOrEmpty(inventory.CustomString2Name))
            {
                <div class="mb-3"><label class="form-label">@inventory.CustomString2Name</label><input asp-for="Command.CustomString2Value" class="form-control" /></div>
            }
            @if (!string.IsNullOrEmpty(inventory.CustomString3Name))
            {
                <div class="mb-3"><label class="form-label">@inventory.CustomString3Name</label><input asp-for="Command.CustomString3Value" class="form-control" /></div>
            }
            @if (!string.IsNullOrEmpty(inventory.CustomInt1Name))
            {
                <div class="mb-3"><label class="form-label">@inventory.CustomInt1Name</label><input asp-for="Command.CustomInt1Value" class="form-control" type="number" step="any" /></div>
            }
            @if (!string.IsNullOrEmpty(inventory.CustomInt2Name))
            {
                <div class="mb-3"><label class="form-label">@inventory.CustomInt2Name</label><input asp-for="Command.CustomInt2Value" class="form-control" type="number" step="any" /></div>
            }
            @if (!string.IsNullOrEmpty(inventory.CustomInt3Name))
            {
                <div class="mb-3"><label class="form-label">@inventory.CustomInt3Name</label><input asp-for="Command.CustomInt3Value" class="form-control" type="number" step="any" /></div>
            }
            @if (!string.IsNullOrEmpty(inventory.CustomText1Name))
            {
                <div class="mb-3"><label class="form-label">@inventory.CustomText1Name</label><textarea asp-for="Command.CustomText1Value" class="form-control" rows="3"></textarea></div>
            }
            @if (!string.IsNullOrEmpty(inventory.CustomText2Name))
            {
                <div class="mb-3"><label class="form-label">@inventory.CustomText2Name</label><textarea asp-for="Command.CustomText2Value" class="form-control" rows="3"></textarea></div>
            }
            @if (!string.IsNullOrEmpty(inventory.CustomText3Name))
            {
                <div class="mb-3"><label class="form-label">@inventory.CustomText3Name</label><textarea asp-for="Command.CustomText3Value" class="form-control" rows="3"></textarea></div>
            }
            @if (!string.IsNullOrEmpty(inventory.CustomBool1Name))
            {
                <div class="mb-3 form-check">
                    <input type="checkbox" class="form-check-input" name="Command.CustomBool1Value"
                           value="true" @(Model.Command.CustomBool1Value == true ? "checked" : "") />
                    <input type="hidden" name="Command.CustomBool1Value" value="false" />
                    <label class="form-check-label">@inventory.CustomBool1Name</label>
                </div>
            }
            @if (!string.IsNullOrEmpty(inventory.CustomBool2Name))
            {
                <div class="mb-3 form-check">
                    <input type="checkbox" class="form-check-input" name="Command.CustomBool2Value"
                           value="true" @(Model.Command.CustomBool2Value == true ? "checked" : "") />
                    <input type="hidden" name="Command.CustomBool2Value" value="false" />
                    <label class="form-check-label">@inventory.CustomBool2Name</label>
                </div>
            }
            @if (!string.IsNullOrEmpty(inventory.CustomBool3Name))
            {
                <div class="mb-3 form-check">
                    <input type="checkbox" class="form-check-input" name="Command.CustomBool3Value"
                           value="true" @(Model.Command.CustomBool3Value == true ? "checked" : "") />
                    <input type="hidden" name="Command.CustomBool3Value" value="false" />
                    <label class="form-check-label">@inventory.CustomBool3Name</label>
                </div>
            }
            @if (!string.IsNullOrEmpty(inventory.CustomLink1Name))
            {
                <div class="mb-3"><label class="form-label">@inventory.CustomLink1Name</label><input asp-for="Command.CustomLink1Value" class="form-control" placeholder="https://..." /></div>
            }
            @if (!string.IsNullOrEmpty(inventory.CustomLink2Name))
            {
                <div class="mb-3"><label class="form-label">@inventory.CustomLink2Name</label><input asp-for="Command.CustomLink2Value" class="form-control" placeholder="https://..." /></div>
            }
            @if (!string.IsNullOrEmpty(inventory.CustomLink3Name))
            {
                <div class="mb-3"><label class="form-label">@inventory.CustomLink3Name</label><input asp-for="Command.CustomLink3Value" class="form-control" placeholder="https://..." /></div>
            }

            @if (string.IsNullOrEmpty(inventory.CustomString1Name) && string.IsNullOrEmpty(inventory.CustomInt1Name) && string.IsNullOrEmpty(inventory.CustomText1Name) && string.IsNullOrEmpty(inventory.CustomBool1Name) && string.IsNullOrEmpty(inventory.CustomLink1Name))
            {
                <div class="alert alert-info">This inventory has no custom fields.</div>
            }
            <div class="mb-3">
                <label class="form-label">Photo</label>
                <input type="file" id="itemImageUpload" class="form-control" accept="image/*" />
                @if (!string.IsNullOrEmpty(Model.Command.ImageUrl))
                {
                    <div class="mt-2">
                        <img src="@Model.Command.ImageUrl" style="max-height:150px; border-radius:8px;" />
                    </div>
                }
                <input type="hidden" asp-for="Command.ImageUrl" id="ItemImageUrl" />
            </div>

            <div class="d-flex gap-2 mt-3">
                <button type="submit" id="saveBtn" class="btn btn-primary">Save Changes</button>
                <a asp-action="Details" asp-route-id="@cmd.Id" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
            document.getElementById('itemImageUpload')?.addEventListener('change', async function() {
            const file = this.files[0];
            if (!file) return;

            const saveBtn = document.getElementById('saveBtn');
            saveBtn.disabled = true;
            saveBtn.textContent = 'Uploading photo...';

            const formData = new FormData();
            formData.append('file', file);
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            const response = await fetch('/Item/UploadImage', {
                method: 'POST',
                headers: { 'RequestVerificationToken': token },
                body: formData
            });

            if (response.ok) {
                const data = await response.json();
                document.getElementById('ItemImageUrl').value = data.url;
                saveBtn.textContent = 'Save Changes';
                saveBtn.disabled = false;
            } else {
                saveBtn.textContent = 'Save Changes';
                saveBtn.disabled = false;
                showToast('Photo upload failed', true);
            }
        });
    </script>
}

