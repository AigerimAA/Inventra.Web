@using Inventra.Application.DTOs
@using Inventra.Web.Models
@model HomeViewModel
@{
    ViewData["Title"] = "Home";
}

<div style="background:#0097a7; padding:70px 48px; margin:-16px -12px 0; text-align:center;">
    <div style="max-width:700px; margin:0 auto;">
        <img src="~/images/logo-white.svg" alt="Inventra" height="48" style="margin-bottom:24px;" />
        <h1 id="heroText" style="color:white; font-size:2rem; font-weight:500; margin:0 0 20px; min-height:3em;"></h1>
        @if (!User.Identity?.IsAuthenticated ?? true)
        {
            <a asp-controller="Account" asp-action="Register"
                   class="hero-btn"
                   style="display:inline-block; background:white; color:#0097a7; padding:12px 32px; border-radius:8px; font-weight:500; text-decoration:none; font-size:15px; transition:all 0.2s;">
                @L["GetStarted"]
            </a>
        }
        else
        {
            <a asp-controller="Inventory" asp-action="Create"
                   class="hero-btn"
                   style="display:inline-block; background:white; color:#0097a7; padding:12px 32px; border-radius:8px; font-weight:500; text-decoration:none; font-size:15px; transition:all 0.2s;">
                @L["NewInventory"]
            </a>
        }
    </div>
</div>

<style>
    .hero-btn {
        background: white !important;
    }
    .hero-btn:hover {
        background: white !important;
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(0,0,0,0.2);
        opacity: 0.95;
    }
</style>

<span id="heroTagline" style="display:none;">@L["Tagline"]</span>

<script>
    const heroText = document.getElementById('heroTagline').textContent;
    let i = 0;
    const el = document.getElementById('heroText');
    function type() {
        if (i < heroText.length) {
            el.textContent += heroText[i];
            i++;
            setTimeout(type, 60);
        }
    }
    type();
</script>


<style>
.inv-card { border-radius: 12px; overflow: hidden; border: 0.5px solid var(--bs-border-color); margin-top: 24px; }
.inv-card-header { background: #0097a7; padding: 14px 20px; }
.inv-card-header span { color: white; font-size: 15px; font-weight: 500; }
.inv-table { width: 100%; border-collapse: collapse; }
.inv-table thead tr { border-bottom: 0.5px solid var(--bs-border-color); }
.inv-table thead th { padding: 10px 16px; font-size: 12px; font-weight: 500; color: var(--bs-secondary-color); text-transform: uppercase; letter-spacing: 0.05em; }
.inv-table tbody tr { border-bottom: 0.5px solid var(--bs-border-color); transition: background 0.15s; cursor: pointer; }
.inv-table tbody tr:hover { background: rgba(0,151,167,0.06); }
.inv-table tbody tr:last-child { border-bottom: none; }
.inv-table tbody td { padding: 12px 16px; font-size: 14px; }
.inv-badge { display: inline-block; background: rgba(0,151,167,0.12); color: #0097a7; font-size: 12px; padding: 2px 8px; border-radius: 20px; font-weight: 500; }
.inv-count { font-weight: 500; color: #0097a7; }
.tag-track { overflow: hidden; height: 32px; position: relative; }
.tag-row { display: flex; gap: 8px; position: absolute; white-space: nowrap; }
.tag-row a { font-size: 12px !important; }
.tag-row-1 { animation: scrollRight 40s linear infinite; }
.tag-row-2 { animation: scrollLeft 50s linear infinite; }
.tag-row-3 { animation: scrollRight 45s linear infinite; }

@@media (max-width: 768px) {
    .home-grid {
        grid-template-columns: 1fr !important;
    }
}
</style>

<div style="display:grid; grid-template-columns: 2fr 1fr; gap: 20px; padding: 8px 0 24px;" class="home-grid">

    <div class="inv-card">
        <div class="inv-card-header">
            <span>@L["LatestInventories"]</span>
        </div>
        <table class="inv-table">
            <thead>
                <tr>
                    <th>@L["Title"]</th>
                    <th>@L["CategoryLabel"]</th>
                    <th>@L["Creator"]</th>
                    <th style="text-align:right;">@L["Items"]</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.LatestInventories.Any())
                {
                    <tr><td colspan="4" style="text-align:center; padding:24px; color:var(--bs-secondary-color);">@L["NoInventoriesYet"]</td></tr>
                }
                else
                {
                    @foreach (var inv in Model.LatestInventories)
                    {
                        <tr onclick="window.location='/Inventory/Details/@inv.Id'">
                            <td style="font-weight:500;">@inv.Title</td>
                            <td><span class="inv-badge">@inv.CategoryName</span></td>
                            <td style="color:var(--bs-secondary-color);">@inv.OwnerName</td>
                            <td style="text-align:right;" class="inv-count">@inv.ItemsCount</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div>
        <div class="inv-card">
            <div class="inv-card-header">
                <span>@L["Top5Popular"]</span>
            </div>
            <table class="inv-table">
                <thead>
                    <tr>
                        <th>@L["Title"]</th>
                        <th style="text-align:right;">@L["Items"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.PopularInventories.Any())
                    {
                        <tr><td colspan="2" style="text-align:center; padding:24px; color:var(--bs-secondary-color);">@L["NoInventoriesYet"]</td></tr>
                    }
                    else
                    {
                        @foreach (var inv in Model.PopularInventories)
                        {
                            <tr onclick="window.location='/Inventory/Details/@inv.Id'">
                                <td style="font-weight:500;">@inv.Title</td>
                                <td style="text-align:right;" class="inv-count">@inv.ItemsCount</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="inv-card" style="margin-top:20px;">
            <div class="inv-card-header">
                <span>@L["Tags"]</span>
            </div>
            

<div style="padding:12px 16px;">
    @if (!Model.TagCloud.Any())
    {
        <span style="color:var(--bs-secondary-color); font-size:14px;">@L["NoTagsYet"]</span>
    }
    else
    {
        var tags = Model.TagCloud.ToList();
        var third = Math.Max(1, tags.Count / 3);
        var row1 = tags.Take(third).ToList();
        var row2 = tags.Skip(third).Take(third).ToList();
        var row3 = tags.Skip(third * 2).ToList();

        string RenderTags(List<Inventra.Application.DTOs.TagCloudItemDto> items, int repeat = 3)
        {
            var sb = new System.Text.StringBuilder();
            for (int r = 0; r < repeat; r++)
            {
                foreach (var tag in items)
                {
                    sb.Append($"<a href='/Search/Index?q={Uri.EscapeDataString(tag.Name)}' class='inv-badge text-decoration-none' title='{tag.Count} inventories'>{tag.Name}</a>");
                }
            }
            return sb.ToString();
        }

        <div class="tag-track">
            <div class="tag-row tag-row-1">@Html.Raw(RenderTags(row1))</div>
        </div>
        <div class="tag-track" style="margin-top:6px;">
            <div class="tag-row tag-row-2">@Html.Raw(RenderTags(row2))</div>
        </div>

        @if (row3.Any())
        {
            <div class="tag-track" style="margin-top:6px;">
                <div class="tag-row tag-row-3">@Html.Raw(RenderTags(row3))</div>
            </div>
        }
    }
            </div>
        </div>
    </div>
</div>
<script>
    const at = String.fromCharCode(64);
    const style = document.createElement('style');
    style.textContent = 
        at + 'keyframes scrollRight { 0% { transform: translateX(-50%); } 100% { transform: translateX(0%); } } ' +
        at + 'keyframes scrollLeft { 0% { transform: translateX(0%); } 100% { transform: translateX(-50%); } }';
    document.head.appendChild(style);
</script>